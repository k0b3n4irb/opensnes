# Credentials
.env

# Build outputs
*.o
*.obj
*.a
*.lib
*.sfc
*.sym
*.map
*.oops

# Binary executables (rebuilt from source)
tools/font2snes/font2snes
tools/gfx4snes/gfx4snes
tools/img2snes/img2snes
tools/sa1-patch/sa1_patch
tools/smconv/smconv

# Generated documentation
doc/

# Compiler intermediates
*.ps
*.asp

# Tool outputs (gfx4snes, smconv)
*.pic
*.pal
*.brr
*.pc7
*.mp7
*.bnk
*.srm
*.inc
*_data.as

# WLA-DX
linkfile
testlink

# IDE (track shared VS Code config, ignore personal settings)
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/extensions.json
.idea/
*.swp
*.swo

# Python
__pycache__/
*.pyc

# macOS
.DS_Store
**/.DS_Store

# Claude Code project config — tracked, except for personal local overrides
.claude/settings.local.json

# Private game projects (never commit) — anchored to repo root so it
# doesn't accidentally match `.claude/notes/projects/` etc.
/projects/

# Build directories
build/
bin/
release/

# Temporary files
*.log
*.tmp
*.bak

# Build artifacts (generated files)
*.asm
*.bin
*.h

# But track source files (not generated artifacts)
!lib/source/*.asm
!lib/source/*.inc
!lib/include/**/*.h
!lib/include/**/*.inc
!lib/source/**/*.h
!templates/**/*.asm
!templates/**/*.inc
!examples/**/data.asm
!examples/**/spc.asm
!examples/**/hero*_meta.inc
# Hand-curated binary assets that are NOT generated by gfx4snes/smconv —
# checked into the repo as canonical sources (e.g. extracted pre-computed
# tables). The wildcard rejects *.bin globally; this exception keeps the
# tracked ones alive.
!examples/graphics/effects/hdma_wave/res/*.bin
!tools/**/*.h
!tests/**/*.inc

.mcp.json
