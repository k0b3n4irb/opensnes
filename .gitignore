# Credentials
.env

# Build outputs
*.o
*.obj
*.a
*.lib
*.sfc
*.sym
*.map
*.oops

# Binary executables (rebuilt from source)
tools/font2snes/font2snes
tools/gfx4snes/gfx4snes
tools/img2snes/img2snes
tools/smconv/smconv

# Generated documentation
doc/

# Compiler intermediates
*.ps
*.asp

# Tool outputs (gfx4snes, smconv)
*.pic
*.pal
*.brr
*.pc7
*.mp7
*.bnk
*.srm
*.inc
*_data.as

# WLA-DX
linkfile
testlink

# IDE (track shared VS Code config, ignore personal settings)
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/extensions.json
.idea/
*.swp
*.swo

# Python
__pycache__/
*.pyc

# macOS
.DS_Store
**/.DS_Store

# Claude Code (internal tooling — not part of the public project)
.claude/
CLAUDE.md
tests/CLAUDE.md

# Private game projects (never commit)
projects/

# Build directories
build/
bin/
release/

# Temporary files
*.log
*.tmp
*.bak

# Build artifacts (generated files)
*.asm
*.obj
*.sfc
*.h

# But track source files (not generated artifacts)
!lib/source/*.asm
!lib/source/*.inc
!lib/include/**/*.h
!lib/include/**/*.inc
!templates/**/*.asm
!templates/**/*.inc
!examples/**/data.asm
!examples/**/spc.asm
!examples/**/hero*_meta.inc
!tools/**/*.h
!tests/**/*.inc

