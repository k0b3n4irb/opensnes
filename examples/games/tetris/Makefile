# Tetris — Mode 1, 3-BG architecture (playfield / HUD / messages)
OPENSNES := $(shell cd ../../.. && pwd)
TARGET   := tetris.sfc
ROM_NAME := OPENSNES TETRIS

CSRC     := main.c board.c piece.c render.c hud.c
ASMSRC   := data.asm

USE_LIB  := 1
LIB_MODULES := console sprite dma background input

include $(OPENSNES)/make/common.mk

res/tiles.pic res/tiles.pal: res/tiles.png
	@echo "[GFX] $<"
	@$(GFX4SNES) -s 8 -o 16 -u 16 -p -i $<

# font2bpp.bin is pre-generated by res/gen_tiles.py (raw 2bpp SNES tiles)
combined.asm: res/tiles.pic res/font2bpp.bin

clean: clean-tetris
.PHONY: clean-tetris
clean-tetris:
	@rm -f res/tiles.pic res/tiles.pal res/tiles.inc res/tiles_data.as
