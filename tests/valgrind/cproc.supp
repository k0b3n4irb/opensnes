# Valgrind suppressions for cproc-qbe
#
# Only suppress pre-existing upstream bugs (NOT leaks).
# Leaks are handled by --errors-for-leak-kinds=definite in the script.

# cproc uses memcpy() for self-copies in preprocessor token handling
# (pp.c, next() function). Benign in practice but technically UB.
{
   cproc_pp_next_self_memcpy
   Memcheck:Overlap
   fun:__GI_memcpy
   fun:next
   ...
}

# emitdata() reads uninitialized struct fields in tentative definitions.
{
   cproc_emitdata_uninit
   Memcheck:Cond
   fun:emitdata
   ...
}
