{
    "version": "2.0.0",
    "tasks": [
        // ── Build ────────────────────────────────────────────────
        {
            "label": "Build All",
            "type": "shell",
            "command": "make",
            "group": { "kind": "build", "isDefault": true },
            "problemMatcher": "$gcc",
            "presentation": { "reveal": "always", "clear": true }
        },
        {
            "label": "Build Compiler",
            "type": "shell",
            "command": "make compiler",
            "problemMatcher": "$gcc"
        },
        {
            "label": "Build Tools",
            "type": "shell",
            "command": "make tools",
            "problemMatcher": "$gcc"
        },
        {
            "label": "Build Library",
            "type": "shell",
            "command": "make lib",
            "problemMatcher": "$gcc"
        },
        {
            "label": "Build Examples",
            "type": "shell",
            "command": "make examples",
            "problemMatcher": "$gcc"
        },
        {
            "label": "Build Current Example",
            "type": "shell",
            "command": "make",
            "options": { "cwd": "${fileDirname}" },
            "problemMatcher": "$gcc",
            "presentation": { "reveal": "always", "clear": true }
        },
        {
            "label": "Clean",
            "type": "shell",
            "command": "make clean",
            "problemMatcher": []
        },
        {
            "label": "Clean & Build All",
            "type": "shell",
            "command": "make clean && make",
            "group": "build",
            "problemMatcher": "$gcc",
            "presentation": { "reveal": "always", "clear": true }
        },

        // ── Tests (luna harness — see make tests) ────────────────
        {
            "label": "Run Tests (luna)",
            "type": "shell",
            "command": "make tests",
            "group": { "kind": "test", "isDefault": true },
            "problemMatcher": [],
            "presentation": { "reveal": "always", "clear": true }
        },
        {
            "label": "Run Compiler Tests",
            "type": "shell",
            "command": "make test-compiler",
            "group": "test",
            "problemMatcher": []
        }
    ]
}
