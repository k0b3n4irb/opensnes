#!/bin/bash
# cc65816 - C compiler for 65816/SNES
# Uses cproc (C frontend) + QBE (optimizer) to generate WLA-DX assembly
#
# Usage: cc65816 input.c [-o output.asm]

set -e
set -o pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
CPROC="$SCRIPT_DIR/cproc-qbe"
QBE="$SCRIPT_DIR/qbe"

usage() {
    echo "Usage: cc65816 input.c [-o output.asm]"
    echo "  Compiles C source to 65816 assembly for SNES"
    echo ""
    echo "Options:"
    echo "  -o FILE    Output assembly to FILE (default: stdout)"
    echo "  -I DIR     Add include directory"
    echo "  -D NAME    Define preprocessor macro"
    echo "  -h         Show this help"
    exit 1
}

INPUT=""
OUTPUT=""
CFLAGS=()

while [[ $# -gt 0 ]]; do
    case $1 in
        -o)
            OUTPUT="$2"
            shift 2
            ;;
        -I|-D)
            CFLAGS+=("$1" "$2")
            shift 2
            ;;
        -I*|-D*)
            CFLAGS+=("$1")
            shift
            ;;
        -h|--help)
            usage
            ;;
        -*)
            echo "Unknown option: $1" >&2
            usage
            ;;
        *)
            if [[ -z "$INPUT" ]]; then
                INPUT="$1"
            else
                echo "Multiple input files not supported" >&2
                exit 1
            fi
            shift
            ;;
    esac
done

if [[ -z "$INPUT" ]]; then
    echo "Error: No input file specified" >&2
    usage
fi

if [[ ! -f "$INPUT" ]]; then
    echo "Error: Input file not found: $INPUT" >&2
    exit 1
fi

# Create unique temp files using mktemp
# -t template: portable across macOS, Linux, and Git Bash/MSYS on Windows
TMPFILE=$(mktemp -t cc65816.XXXXXX) || TMPFILE=$(mktemp)
IRFILE=$(mktemp -t cc65816_ir.XXXXXX) || IRFILE=$(mktemp)
trap 'rm -f "$TMPFILE" "$IRFILE"' EXIT

# Stage 1: Preprocess with system cc.
# `-D__OPENSNES__=1` lets headers detect that they're being preprocessed
# for the cc65816 target (vs the `clang -fsyntax-only` host lint pass
# in make/common.mk, which compiles the same source with host int/long
# sizes). lib/include/snes/types.h uses this to keep `sizeof(s32) == 4`
# on both code paths despite cc65816 having long=4 and host having long=8.
cc -E -D__OPENSNES__=1 "${CFLAGS[@]}" "$INPUT" > "$TMPFILE"

# Cooper: under -g, tell cproc where to write the aggregate-layout sidecar
# (struct/array type trees for the debugger's Locals expansion).
if [[ -n "$CC65816_G" && -n "$OUTPUT" ]]; then
    export CC65816_DBG="${OUTPUT%.asm}.dbg"
fi

# Stage 2: C frontend -> QBE IR (to temp file, NOT a pipe)
# Using a pipe hides cproc crashes: QBE receives truncated IR and reports
# misleading parse errors. With a temp file, cproc failures are caught cleanly.
#
# cproc occasionally segfaults on MSYS2 (Windows). Retry up to 2 times on
# signal 139 (SIGSEGV) before giving up. This does not mask real errors —
# compilation failures with exit code != 139 are not retried.
CPROC_RETRIES=3
for _try in $(seq 1 $CPROC_RETRIES); do
    set +e
    "$CPROC" "$TMPFILE" > "$IRFILE" 2>/tmp/cc65816_cproc_err.$$
    CPROC_EXIT=$?
    set -e

    if [[ $CPROC_EXIT -eq 0 ]]; then
        break
    fi

    # Exit code 139 = killed by signal 11 (SIGSEGV)
    if [[ $CPROC_EXIT -eq 139 ]] && [[ $_try -lt $CPROC_RETRIES ]]; then
        echo "cc65816: cproc segfault (attempt $_try/$CPROC_RETRIES), retrying..." >&2
        continue
    fi

    # Not a segfault or last retry — propagate the error
    cat /tmp/cc65816_cproc_err.$$ >&2
    rm -f /tmp/cc65816_cproc_err.$$
    exit $CPROC_EXIT
done
rm -f /tmp/cc65816_cproc_err.$$

# Stage 3: QBE IR -> 65816 assembly
# Cooper source-level debug: CC65816_G=1 passes -g (keep C locals in memory) so
# the debugger can read typed locals. Off by default (it disables optimisation).
QBE_G=""
[[ -n "$CC65816_G" ]] && QBE_G="-g"
if [[ -z "$OUTPUT" ]]; then
    "$QBE" $QBE_G -t w65816 "$IRFILE"
else
    "$QBE" $QBE_G -t w65816 "$IRFILE" > "$OUTPUT"
    echo "Generated: $OUTPUT"
fi
